<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Acción principal -->
    <record id="action_it_informes" model="ir.actions.act_window">
        <field name="name">Informes</field>
        <field name="res_model">it.informe</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p>Crea y gestiona Informes de Turno.</p>
        </field>
    </record>

    <!-- Menús -->
    <menuitem id="menu_it_root" name="Operaciones" sequence="10"/>
    <menuitem id="menu_it_informe" name="Informe" parent="menu_it_root" sequence="10"/>
    <menuitem id="menu_it_tablas" name="Tablas" parent="menu_it_root" sequence="20"/>
    <menuitem id="menu_it_personas" name="Personas" parent="menu_it_root" sequence="30"/>
    <menuitem id="menu_it_informes" name="Informes" parent="menu_it_informe" action="action_it_informes" sequence="10"/>

    <!-- Tablas auxiliares -->
    <record id="action_it_area" model="ir.actions.act_window">
        <field name="name">Áreas</field>
        <field name="res_model">it.area</field>
        <field name="view_mode">list,form</field>
    </record>
    <menuitem id="menu_it_area" name="Áreas" parent="menu_it_tablas" action="action_it_area" sequence="10"/>

    <record id="action_it_especialidad" model="ir.actions.act_window">
        <field name="name">Especialidades</field>
        <field name="res_model">it.especialidad</field>
        <field name="view_mode">list,form</field>
    </record>
    <menuitem id="menu_it_especialidad" name="Especialidades" parent="menu_it_tablas" action="action_it_especialidad" sequence="30"/>


    <!-- Empleados solo lectura -->
    <record id="view_hr_employee_list_readonly" model="ir.ui.view">
        <field name="name">hr.employee.list.readonly.for.it</field>
        <field name="model">hr.employee</field>
        <field name="arch" type="xml">
            <list create="0" edit="0" delete="0">
                <field name="identification_id"/>
                <field name="name"/>
                <field name="job_id"/>
                <field name="work_email"/>
                <field name="work_phone"/>
                <field name="category_ids"/>
            </list>
        </field>
    </record>

    <record id="action_it_employees_readonly" model="ir.actions.act_window">
        <field name="name">Empleados (solo lectura)</field>
        <field name="res_model">hr.employee</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_hr_employee_list_readonly"/>
    </record>
    <menuitem id="menu_it_employees_readonly" name="Empleados (solo lectura)" parent="menu_it_personas" action="action_it_employees_readonly" sequence="10"/>

    <record id="action_hr_employee_category" model="ir.actions.act_window">
        <field name="name">Etiquetas de cargo</field>
        <field name="res_model">hr.employee.category</field>
        <field name="view_mode">list,form</field>
    </record>
    <menuitem id="menu_it_employee_category" name="Etiquetas de cargo" parent="menu_it_personas" action="action_hr_employee_category" sequence="20"/>

    <!-- Vista list -->
    <record id="it_informe_list" model="ir.ui.view">
        <field name="name">it.informe.list</field>
        <field name="model">it.informe</field>
        <field name="arch" type="xml">
            <list string="Informes" create="true" delete="true">
                <field name="code" optional="show"/>
                <field name="orden_servicio_id" string="Proyecto" optional="show"/>
                <field name="proyecto_codigo" optional="show"/>
                <field name="proyecto_nombre" optional="show"/>
                <field name="fecha_ejecucion" optional="show"/>
                <field name="establecimiento_id" optional="show"/>
                <field name="area_id" optional="show"/>
                <field name="tipo_trabajo_id" optional="show"/>
                <field name="tipo_servicio_id" optional="show"/>
                <field name="supervisor_id" optional="show"/>
                <field name="hora_entrada_real" optional="show"/>
                <field name="hora_entrada_real_fecha" optional="show"/>
                <field name="hora_inicio_faena" optional="show"/>
                <field name="hora_inicio_faena_fecha" optional="show"/>
                <field name="hora_fin_faena" optional="show"/>
                <field name="hora_fin_faena_fecha" optional="show"/>
                <field name="hora_salida_real" optional="show"/>
                <field name="hora_salida_real_fecha" optional="show"/>
                <field name="operador_ids" widget="many2many_tags" optional="hide"/>
                <field name="operador_servicio_ids" widget="many2many_tags" optional="hide"/>
                <field name="nombre_equipo" optional="hide"/>
                <field name="tag" optional="hide"/>
                <field name="especialidad_id" optional="hide"/>
                <field name="descripcion" optional="hide"/>
                <field name="observaciones_servicio" optional="hide"/>
                <field name="ito_planta" optional="hide"/>
                <field name="prevencionista_id" optional="hide"/>
                <field name="vehiculo_count" optional="hide"/>
                <field name="alojamiento" optional="hide"/>
                <field name="cant_personas" optional="hide"/>
                <field name="barreras_quimica" optional="hide"/>
                <field name="cant_barreras_quimicas" optional="hide"/>
                <field name="aspirado_alta_temperatura" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Vista Form -->
    <record id="it_informe_form" model="ir.ui.view">
        <field name="name">it.informe.form</field>
        <field name="model">it.informe</field>
        <field name="arch" type="xml">
            <form string="Informe de Turno">
                <sheet>
                    <group col="6">
                        <field name="code" modifiers="{'readonly':[('id','!=',False)]}"/>
                        <field name="orden_servicio_id" options="{'no_create': True}"/>
                        <field name="proyecto_codigo" readonly="1"/>
                        <field name="proyecto_nombre" readonly="1"/>
                        <field name="fecha_ejecucion"/>
                        <field name="establecimiento_id" options="{'no_create_edit':True}"
                               readonly="orden_servicio_id"/>
                        <field name="supervisor_id" readonly="1"/>
                    </group>

                    <notebook>
                        <!-- Página Servicio -->
                        <page string="Servicio">
                            <group>
                                <div style="display: grid; grid-template-columns: 200px 120px 140px; row-gap: 8px; column-gap: 12px;">

                                    <!-- Fila 1 -->
                                    <span class="o_form_label">Hora entrada real</span>
                                    <field name="hora_entrada_real" class="oe_inline"/>
                                    <field name="hora_entrada_real_fecha" class="oe_inline" readonly="1" nolabel="1"/>

                                    <!-- Fila 2 -->
                                    <span class="o_form_label">Hora inicio faena</span>
                                    <field name="hora_inicio_faena" class="oe_inline"/>
                                    <field name="hora_inicio_faena_fecha" class="oe_inline" readonly="1" nolabel="1"/>

                                    <!-- Fila 3 -->
                                    <span class="o_form_label">Hora fin faena</span>
                                    <field name="hora_fin_faena" class="oe_inline"/>
                                    <field name="hora_fin_faena_fecha" class="oe_inline" readonly="1" nolabel="1"/>

                                    <!-- Fila 4 -->
                                    <span class="o_form_label">Hora salida real</span>
                                    <field name="hora_salida_real" class="oe_inline"/>
                                    <field name="hora_salida_real_fecha" class="oe_inline" readonly="1" nolabel="1"/>

                                </div>
                            </group>

                            <group col="2">
                                <!-- Campos adicionales -->
                                <field name="area_id"/>
                                <field name="nombre_equipo"/>
                                <field name="tag"/>
                                <field name="tipo_trabajo_id" readonly="orden_servicio_id"/>
                                <field name="tipo_servicio_id" readonly="orden_servicio_id"/>
                                <field name="especialidad_id"/>
                                <field name="descripcion" readonly="orden_servicio_id"/>
                                <field name="observaciones_servicio"/>
                            </group>
                        </page>

                        <!-- Página Personas -->
                        <page string="Personas">
                            <group col="4">
                                <field name="ito_planta"/>
                                <field name="prevencionista_id"/>
                                <field name="operador_ids" widget="many2many_tags"/>
                                <field name="operador_servicio_ids" widget="many2many_tags"/>
                            </group>
                        </page>

                        <!-- Página Recursos -->
                        <page string="Recursos">
                            <group>
                                <field name="vehiculo_line_ids">
                                    <list editable="bottom">
                                        <field name="tipo_vehiculo_id"/>
                                        <field name="vehiculo_id" domain="[('category_id', '=', tipo_vehiculo_id)]"/>
                                        <field name="medida"/>
                                        <field name="lts_petroline"/>
                                    </list>
                                </field>
                            </group>
                        </page>

                        <!-- Página Otros -->
                        <page string="Otros">
                            <group col="4">
                                <field name="alojamiento"/>
                                <field name="cant_personas"/>
                                <field name="barreras_quimica"/>
                                <field name="cant_barreras_quimicas"/>
                                <field name="aspirado_alta_temperatura"/>
                            </group>
                        </page>

                        <!-- Página Adjuntos -->
                        <page string="Adjuntos">
                            <group col="2">
                                <separator string="Informe de Turno"/>
                                <field name="doc_informe_turno" filename="doc_informe_turno_name" widget="binary"/>
                                <separator string="Informe de Capacitación"/>
                                <field name="doc_informe_capacitacion" filename="doc_informe_capacitacion_name" widget="binary"/>
                            </group>

                            <group string="Fotos Antes/Después">
                                <field name="foto_pair_ids" context="{'default_informe_id': id}">
                                    <list editable="bottom">
                                        <field name="sequence" widget="handle"/>
                                        <field name="etiqueta"/>
                                        <field name="foto_antes" widget="image"/>
                                        <field name="foto_despues" widget="image"/>
                                    </list>
                                </field>
                            </group>
                        </page>

                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
