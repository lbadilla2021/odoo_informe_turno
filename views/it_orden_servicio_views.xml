<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_it_orden_servicio_tree" model="ir.ui.view">
        <field name="name">it.orden.servicio.tree</field>
        <field name="model">it.orden.servicio</field>
        <field name="arch" type="xml">
            <tree string="Órdenes de Servicio">
                <field name="name"/>
                <field name="descripcion_servicio"/>
                <field name="establecimiento_id"/>
                <field name="cliente_id"/>
                <field name="tipo_trabajo_id"/>
                <field name="tipo_servicio_id"/>
                <field name="estado"/>
            </tree>
        </field>
    </record>

    <record id="view_it_orden_servicio_form" model="ir.ui.view">
        <field name="name">it.orden.servicio.form</field>
        <field name="model">it.orden.servicio</field>
        <field name="arch" type="xml">
            <form string="Orden de Servicio">
                <sheet>
                    <group col="4">
                        <field name="name"/>
                        <field name="numero_pedido"/>
                        <field name="ito"/>
                        <field name="estado"/>
                        <field name="cliente_id" options="{'no_create_edit': True}"/>
                        <field name="establecimiento_id" options="{'no_create_edit': True}"/>
                        <field name="tipo_trabajo_id"/>
                        <field name="tipo_servicio_id"/>
                        <field name="duracion_horas"/>
                        <field name="cantidad_equipos"/>
                    </group>
                    <group>
                        <field name="descripcion_servicio" colspan="4"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_it_orden_servicio" model="ir.actions.act_window">
        <field name="name">Órdenes de Servicio</field>
        <field name="res_model">it.orden.servicio</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
