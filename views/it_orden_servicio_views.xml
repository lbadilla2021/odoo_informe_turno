<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_it_orden_servicio_tree" model="ir.ui.view">
        <field name="name">it.orden.servicio.tree</field>
        <field name="model">it.orden.servicio</field>
        <field name="arch" type="xml">
            <tree string="Órdenes de Servicio">
                <field name="name"/>
                <field name="numero_pedido"/>
                <field name="descripcion_servicio"/>
                <field name="cliente_id"/>
                <field name="establecimiento_id"/>
                <field name="tipo_trabajo_id"/>
                <field name="tipo_servicio_id"/>
                <field name="fecha_adjudicacion"/>
                <field name="fecha_inicio_programada"/>
                <field name="fecha_termino_programada"/>
                <field name="valor_adjudicado"/>
                <field name="valor_final"/>
                <field name="estado"/>
            </tree>
        </field>
    </record>

    <record id="view_it_orden_servicio_form" model="ir.ui.view">
        <field name="name">it.orden.servicio.form</field>
        <field name="model">it.orden.servicio</field>
        <field name="arch" type="xml">
            <form string="Orden de Servicio">
                <header>
                    <button name="action_descartar" string="Descartar" type="object"
                            invisible="estado != 'licitacion'"/>
                    <button name="action_adjudicar" string="Adjudicar" type="object" class="oe_highlight"
                            invisible="estado != 'licitacion'"/>
                    <button name="action_planificar" string="Planificar" type="object" class="oe_highlight"
                            invisible="estado != 'adjudicado'"/>
                    <button name="action_cobrar" string="Cobrar" type="object" class="oe_highlight"
                            invisible="estado != 'planificado'"/>
                    <button name="action_cerrar" string="Cerrar" type="object" class="oe_highlight"
                            invisible="estado != 'por_cobrar'"/>
                    <field name="estado" widget="statusbar"
                           statusbar_visible="licitacion,perdido,adjudicado,planificado,por_cobrar,cobrado"/>
                </header>
                <sheet>
                    <group col="4">
                        <field name="name"/>
                        <field name="numero_pedido"/>
                        <field name="descripcion_servicio" colspan="2"/>
                        <field name="cliente_id" options="{'no_create_edit': True}"/>
                        <field name="establecimiento_id" options="{'no_create_edit': True}"/>
                        <field name="tipo_trabajo_id"/>
                        <field name="tipo_servicio_id"/>
                        <field name="fecha_adjudicacion"/>
                        <field name="fecha_inicio_programada"/>
                        <field name="fecha_termino_programada"/>
                        <field name="ito"/>
                        <field name="duracion_horas"/>
                        <field name="cantidad_equipos"/>
                        <field name="valor_adjudicado"/>
                        <field name="valor_final"/>
                        <field name="estado"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_it_orden_servicio_kanban" model="ir.ui.view">
        <field name="name">it.orden.servicio.kanban</field>
        <field name="model">it.orden.servicio</field>
        <field name="arch" type="xml">
            <kanban default_group_by="estado" class="o_kanban_small_column">
                <field name="estado"/>
                <field name="cliente_id"/>
                <field name="establecimiento_id"/>
                <field name="tipo_trabajo_id"/>
                <field name="tipo_servicio_id"/>
                <field name="fecha_inicio_programada"/>
                <field name="fecha_termino_programada"/>
                <field name="valor_adjudicado"/>
                <field name="valor_final"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click o_kanban_record">
                            <div class="o_kanban_header">
                                <strong><field name="name"/></strong>
                            </div>
                            <div class="o_kanban_body">
                                <div><span class="o_label">Pedido:</span> <field name="numero_pedido"/></div>
                                <div><span class="o_label">Cliente:</span> <field name="cliente_id"/></div>
                                <div><span class="o_label">Establecimiento:</span> <field name="establecimiento_id"/></div>
                                <div><span class="o_label">Trabajo:</span> <field name="tipo_trabajo_id"/></div>
                                <div><span class="o_label">Servicio:</span> <field name="tipo_servicio_id"/></div>
                                <div><span class="o_label">Estado:</span> <field name="estado"/>
                                </div>
                            </div>
                            <div class="o_kanban_footer">
                                <div><span class="o_label">Inicio:</span> <field name="fecha_inicio_programada"/></div>
                                <div><span class="o_label">Término:</span> <field name="fecha_termino_programada"/></div>
                                <div><span class="o_label">Valor:</span> <field name="valor_final"/></div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_it_orden_servicio" model="ir.actions.act_window">
        <field name="name">Órdenes de Servicio</field>
        <field name="res_model">it.orden.servicio</field>
        <field name="view_mode">kanban,tree,form</field>
    </record>
</odoo>
