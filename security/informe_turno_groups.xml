<odoo>
    <record id="module_category_barca_it" model="ir.module.category">
        <field name="name">Operaciones</field>
        <field name="sequence">31</field>
    </record>

    <record id="group_it_own" model="res.groups">
        <field name="name">Usuario</field>
        <field name="category_id" ref="module_category_barca_it"/>
    </record>

    <record id="group_it_read_all" model="res.groups">
        <field name="name">Solo lectura</field>
        <field name="category_id" ref="module_category_barca_it"/>
        <field name="implied_ids" eval="[(4, ref('informe_turno.group_it_own'))]"/>
    </record>

    <record id="group_it_usuario_comercial" model="res.groups">
        <field name="name">Usuario Comercial</field>
        <field name="category_id" ref="module_category_barca_it"/>
        <field name="implied_ids" eval="[(4, ref('informe_turno.group_it_own'))]"/>
    </record>

</odoo>
