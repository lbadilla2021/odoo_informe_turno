<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="group_it_read_all" model="res.groups">
        <field name="name">Informe Turno / Consulta Global</field>
        <field name="category_id" ref="base.module_category_hidden"/>
    </record>
    <record id="group_it_own" model="res.groups">
        <field name="name">Informe Turno / Supervisor (propios)</field>
        <field name="category_id" ref="base.module_category_hidden"/>
    </record>
    <record id="rule_it_read_all" model="ir.rule">
        <field name="name">it.informe - read all</field>
        <field name="model_id" ref="model_it_informe"/>
        <field name="groups" eval="[(4, ref('informe_turno.group_it_read_all'))]"/>
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>
    <record id="rule_it_own" model="ir.rule">
        <field name="name">it.informe - own</field>
        <field name="model_id" ref="model_it_informe"/>
        <field name="groups" eval="[(4, ref('informe_turno.group_it_own'))]"/>
        <field name="domain_force">[('supervisor_id','=',user.id)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>
</odoo>
